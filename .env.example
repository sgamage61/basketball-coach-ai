# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Basketball Coach AI"
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-secret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/basketball_coach

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.3

# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Cache TTLs (seconds) ─────────────────────────────────────────────────────
GAME_STATE_TTL=3600
RECOMMENDATION_TTL=300
